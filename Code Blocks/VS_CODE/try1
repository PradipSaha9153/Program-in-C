#include<stdio.h>
#include<conio.h>

void swap(int *,int *);
main()
{
    int a,b;

    printf("Enter two number:- ");
    scanf("%d%d",&a,&b);

    printf("A = %d, B = %d\n",a,b);

    swap(&a,&b);

    printf("A = %d, B = %d",a,b);

    getch();
}
void swap(int *x,int *y)
{
    int z;

    z=*x;
    *x=*y;
    *y=z;

}
